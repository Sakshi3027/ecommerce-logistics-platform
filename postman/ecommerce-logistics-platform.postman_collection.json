    {
      "name": "🛒 Order Service (8081)",
      "item": [
        {
          "name": "Place Order",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "http://localhost:8081/api/orders", "host": ["localhost"], "port": "8081", "path": ["api", "orders"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": 1,\n  \"shippingAddress\": \"123 Main St, New York, NY 10001\",\n  \"items\": [\n    {\n      \"productId\": 101,\n      \"productName\": \"iPhone 15 Pro\",\n      \"quantity\": 1,\n      \"unitPrice\": 999.99\n    },\n    {\n      \"productId\": 102,\n      \"productName\": \"MacBook Pro\",\n      \"quantity\": 1,\n      \"unitPrice\": 2499.99\n    }\n  ]\n}"
            }
          }
        },
        {
          "name": "Get Order by ID",
          "request": {
            "method": "GET",
            "url": { "raw": "http://localhost:8081/api/orders/1", "host": ["localhost"], "port": "8081", "path": ["api", "orders", "1"] }
          }
        },
        {
          "name": "Get Order by Number",
          "request": {
            "method": "GET",
            "url": { "raw": "http://localhost:8081/api/orders/number/ORD-12345678", "host": ["localhost"], "port": "8081", "path": ["api", "orders", "number", "ORD-12345678"] }
          }
        },
        {
          "name": "Get Orders by Customer",
          "request": {
            "method": "GET",
            "url": { "raw": "http://localhost:8081/api/orders/customer/1", "host": ["localhost"], "port": "8081", "path": ["api", "orders", "customer", "1"] }
          }
        },
        {
          "name": "Update Order Status → CONFIRMED",
          "request": {
            "method": "PUT",
            "url": { "raw": "http://localhost:8081/api/orders/1/status?status=CONFIRMED", "host": ["localhost"], "port": "8081", "path": ["api", "orders", "1", "status"], "query": [{ "key": "status", "value": "CONFIRMED" }] }
          }
        },
        {
          "name": "Update Order Status → SHIPPED",
          "request": {
            "method": "PUT",
            "url": { "raw": "http://localhost:8081/api/orders/1/status?status=SHIPPED", "host": ["localhost"], "port": "8081", "path": ["api", "orders", "1", "status"], "query": [{ "key": "status", "value": "SHIPPED" }] }
